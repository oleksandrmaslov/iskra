<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="Iskra"
          Manufacturer="Oleksandr Maslov"
          Version="$(var.AppVersion)"
          UpgradeCode="72C2B704-48BD-4F11-A49C-D0805D9EB4E4"
          Compressed="yes"
          DisableModify="button">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="hyperlinkLicense"
          LicenseUrl=""
          ShowVersion="yes"
          SuppressOptionsUI="yes" />
    </BootstrapperApplication>

    <bal:Condition Condition="VersionNT64 &gt;= v10.0"
                   Message="Потрібна Windows 10/11 x64. Встановлення Iskra зупинено." />

    <!-- Used to skip the bundled Arm MSI when a supported gdb is already present. -->
    <util:FileSearch Id="ArmGdb15Search"
                     Variable="ArmGdb15Exists"
                     Result="exists"
                     Path="[ProgramFiles64Folder]Arm\GNU Toolchain mingw-w64-i686-arm-none-eabi\bin\arm-none-eabi-gdb.exe" />
    <util:FileSearch Id="ArmGdb15X86Search"
                     Variable="ArmGdb15X86Exists"
                     Result="exists"
                     Path="[ProgramFilesFolder]Arm\GNU Toolchain mingw-w64-i686-arm-none-eabi\bin\arm-none-eabi-gdb.exe" />
    <util:FileSearch Id="ArmGdbLegacyArm15Search"
                     Variable="ArmGdbLegacyArm15Exists"
                     Result="exists"
                     Path="[ProgramFiles64Folder]Arm GNU Toolchain arm-none-eabi\15.2 rel1\bin\arm-none-eabi-gdb.exe" />
    <util:FileSearch Id="ArmGdbLegacyArm15X86Search"
                     Variable="ArmGdbLegacyArm15X86Exists"
                     Result="exists"
                     Path="[ProgramFilesFolder]Arm GNU Toolchain arm-none-eabi\15.2 rel1\bin\arm-none-eabi-gdb.exe" />
    <util:FileSearch Id="ArmGdbLegacyX86Search"
                     Variable="ArmGdbLegacyX86Exists"
                     Result="exists"
                     Path="[ProgramFilesFolder]GNU Arm Embedded Toolchain\10 2021.10\bin\arm-none-eabi-gdb.exe" />
    <util:FileSearch Id="ArmGdbLegacyArmX86Search"
                     Variable="ArmGdbLegacyArmX86Exists"
                     Result="exists"
                     Path="[ProgramFilesFolder]Arm GNU Toolchain arm-none-eabi\10 2021.10\bin\arm-none-eabi-gdb.exe" />

    <Chain>
      <!-- Third-party prerequisite. Keep it installed if Iskra is removed. -->
      <MsiPackage Id="ArmGnuToolchain"
                  SourceFile="$(var.ArmToolchainMsi)"
                  DisplayName="Arm GNU Toolchain (arm-none-eabi)"
                  InstallCondition="NOT ArmGdb15Exists AND NOT ArmGdb15X86Exists AND NOT ArmGdbLegacyArm15Exists AND NOT ArmGdbLegacyArm15X86Exists AND NOT ArmGdbLegacyX86Exists AND NOT ArmGdbLegacyArmX86Exists"
                  Permanent="yes"
                  Visible="yes"
                  Vital="yes">
        <MsiProperty Name="EULA" Value="1" />
      </MsiPackage>

      <MsiPackage Id="IskraMsi"
                  SourceFile="$(var.IskraMsi)"
                  DisplayName="Iskra"
                  ForcePerMachine="yes"
                  Visible="no"
                  Vital="yes" />
    </Chain>
  </Bundle>
</Wix>
