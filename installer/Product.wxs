<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="FlashlightApp"
           Manufacturer="Oleksandr Maslov"
           Version="$(var.AppVersion)"
           UpgradeCode="EE1F8E50-1E11-4D5B-9B3D-9E1B2C7A8F30"
           Scope="perMachine"
           Language="1058"
           Codepage="1251"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="Black Magic Probe firmware flasher (Ukrainian UI)" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Upgrade policy: install the latest, uninstall older versions automatically. -->
    <MajorUpgrade DowngradeErrorMessage="Уже встановлено новішу версію FlashlightApp." />

    <!-- Default Wix UI: progress + EULA-less minimal install -->
    <ui:WixUI Id="WixUI_Minimal" />

    <Feature Id="MainFeature" Title="FlashlightApp" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ExampleFiles" />
      <ComponentRef Id="AppStartMenuShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="FlashlightApp">
        <Directory Id="ExamplesFolder" Name="examples" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="AppStartMenuShortcut" Guid="2E3F8C50-3A21-4B7C-92AC-7D5E1F2C8B41">
        <Shortcut Id="AppStartMenuShortcutTarget"
                  Name="FlashlightApp"
                  Description="Прошивка через Black Magic Probe"
                  Target="[INSTALLFOLDER]FlashlightApp.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\FlashlightApp"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Source="$(var.PublishDir)\FlashlightApp.exe" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ExampleFiles" Directory="ExamplesFolder">
      <Component>
        <File Source="$(var.SolutionDir)\examples\catalog.json" />
      </Component>
      <Component>
        <File Source="$(var.SolutionDir)\examples\catalog.json.sig" />
      </Component>
    </ComponentGroup>

  </Package>
</Wix>
