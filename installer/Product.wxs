<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Iskra"
           Manufacturer="Oleksandr Maslov"
           Version="$(var.AppVersion)"
           UpgradeCode="EE1F8E50-1E11-4D5B-9B3D-9E1B2C7A8F30"
           Scope="perMachine"
           Language="1058"
           Codepage="1251"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="Black Magic Probe firmware flasher (Ukrainian UI)" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Upgrade policy: install the latest, uninstall older versions automatically. -->
    <MajorUpgrade DowngradeErrorMessage="Уже встановлено новішу версію Iskra." />

    <!-- Standalone MSI gate. The setup EXE installs the Arm toolchain first. -->
    <Property Id="ARM_GDB_15_PATH">
      <DirectorySearch Id="SearchArmGdb15Dir"
                       Path="[ProgramFiles64Folder]Arm\GNU Toolchain mingw-w64-i686-arm-none-eabi\bin">
        <FileSearch Id="SearchArmGdb15File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="ARM_GDB_15_X86_PATH">
      <DirectorySearch Id="SearchArmGdb15X86Dir"
                       Path="[ProgramFilesFolder]Arm\GNU Toolchain mingw-w64-i686-arm-none-eabi\bin">
        <FileSearch Id="SearchArmGdb15X86File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="ARM_GDB_LEGACY_ARM_15_PATH">
      <DirectorySearch Id="SearchArmGdbLegacyArm15Dir"
                       Path="[ProgramFiles64Folder]Arm GNU Toolchain arm-none-eabi\15.2 rel1\bin">
        <FileSearch Id="SearchArmGdbLegacyArm15File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="ARM_GDB_LEGACY_ARM_15_X86_PATH">
      <DirectorySearch Id="SearchArmGdbLegacyArm15X86Dir"
                       Path="[ProgramFilesFolder]Arm GNU Toolchain arm-none-eabi\15.2 rel1\bin">
        <FileSearch Id="SearchArmGdbLegacyArm15X86File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="ARM_GDB_LEGACY_ARM_10_PATH">
      <DirectorySearch Id="SearchArmGdbLegacyArm10Dir"
                       Path="[ProgramFilesFolder]Arm GNU Toolchain arm-none-eabi\10 2021.10\bin">
        <FileSearch Id="SearchArmGdbLegacyArm10File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="ARM_GDB_LEGACY_GNU_10_PATH">
      <DirectorySearch Id="SearchArmGdbLegacyGnu10Dir"
                       Path="[ProgramFilesFolder]GNU Arm Embedded Toolchain\10 2021.10\bin">
        <FileSearch Id="SearchArmGdbLegacyGnu10File" Name="arm-none-eabi-gdb.exe" />
      </DirectorySearch>
    </Property>

    <!-- MSI reports Windows 10/11 as VersionNT64=603/WindowsBuild=9600 in compatibility mode.
         The setup EXE uses Burn's real Windows 10+ check; the MSI uses this native x64 gate. -->
    <Launch Condition="VersionNT64 &gt;= 603"
            Message="Потрібна Windows 10/11 x64. Встановлення Iskra зупинено." />
    <Launch Condition="Installed OR ARM_GDB_15_PATH OR ARM_GDB_15_X86_PATH OR ARM_GDB_LEGACY_ARM_15_PATH OR ARM_GDB_LEGACY_ARM_15_X86_PATH OR ARM_GDB_LEGACY_ARM_10_PATH OR ARM_GDB_LEGACY_GNU_10_PATH"
            Message="Arm GNU Toolchain (arm-none-eabi-gdb.exe) не знайдено. Запустіть Iskra setup EXE або встановіть Arm GNU Toolchain перед MSI." />

    <!-- Default Wix UI: progress + EULA-less minimal install -->
    <ui:WixUI Id="WixUI_Minimal" />

    <Feature Id="MainFeature" Title="Iskra" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ExampleFiles" />
      <ComponentGroupRef Id="StationCheckFiles" />
      <ComponentRef Id="AppStartMenuShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Iskra">
        <Directory Id="ExamplesFolder" Name="examples" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="AppStartMenuShortcut" Guid="2E3F8C50-3A21-4B7C-92AC-7D5E1F2C8B41">
        <Shortcut Id="AppStartMenuShortcutTarget"
                  Name="Iskra"
                  Description="Прошивка через Black Magic Probe"
                  Target="[INSTALLFOLDER]Iskra.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\Iskra"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Source="$(var.PublishDir)\Iskra.exe" />
      </Component>
      <Component>
        <File Source="$(var.CliPublishDir)\Iskra.Cli.exe" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ExampleFiles" Directory="ExamplesFolder">
      <Component>
        <File Source="$(var.SolutionDir)\examples\catalog.json" />
      </Component>
      <Component>
        <File Source="$(var.SolutionDir)\examples\catalog.json.sig" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="StationCheckFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Source="$(var.SolutionDir)\installer\check-station.ps1" />
      </Component>
    </ComponentGroup>

  </Package>
</Wix>
