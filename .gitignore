# OS
Thumbs.db
.DS_Store

# Logs and local databases (operator runs)
*.log
*.sqlite
*.sqlite-journal
*.db
*.db-journal
flasher.sqlite*

# Local firmware cache (developer-only; real cache lives in %ProgramData%)
cache/

# Vendored tools (filled by installer, not by source control)
tools/gdb/

# Firmware binaries — these come from the firmware repo's build output and
# get bundled via the installer or sideload. Never committed to source.
*.elf
*.bin
*.hex
*.priv

# Installer / publish output
publish/
installer/out/
installer/deps/
*.msi
*.wixpdb
