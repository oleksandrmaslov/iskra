<Window x:Class="Iskra.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iskra — масова прошивка"
        Height="800" Width="1100"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status strip (always visible across tabs) -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusPort"    Foreground="#DCDCDC" FontSize="13" Text="Порт: …"     Margin="0,0,24,0" />
                <TextBlock x:Name="StatusGdb"     Foreground="#DCDCDC" FontSize="13" Text="gdb: …"      Margin="0,0,24,0" />
                <TextBlock x:Name="StatusCatalog" Foreground="#DCDCDC" FontSize="13" Text="Каталог: …"  Margin="0,0,24,0" />
                <TextBlock x:Name="StatusCloud"   Foreground="#DCDCDC" FontSize="13" Text="Хмара: …" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" x:Name="MainTabs" Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ============================ FLASH TAB ============================ -->
            <TabItem Header="Прошивка" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <!-- Form -->
                    <Grid Grid.Row="0" Margin="20,16,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Оператор:" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,8" />
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="OperatorBox" FontSize="16" Padding="6,4" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Партія:" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,8" />
                        <TextBox   Grid.Row="0" Grid.Column="4" x:Name="BatchBox" FontSize="16" Padding="6,4" Margin="0,0,0,8" TextChanged="BatchBox_TextChanged" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Продукт:" VerticalAlignment="Center" FontSize="15" />
                        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="ProductCombo" FontSize="16" Padding="6,4" SelectionChanged="ProductCombo_SelectionChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Версія:" VerticalAlignment="Center" FontSize="15" />
                        <ComboBox  Grid.Row="1" Grid.Column="4" x:Name="VersionCombo" FontSize="16" Padding="6,4"
                                   DisplayMemberPath="Version"
                                   SelectionChanged="VersionCombo_SelectionChanged" />

                        <TextBlock x:Name="BatchLockLabel" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                                   Margin="0,6,0,0" Text="" FontSize="13" Foreground="#1B8A1B"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Border Grid.Row="1" x:Name="ResultBanner" Margin="20,8,20,8" CornerRadius="10" Background="#E8E8E8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="ResultText" Text="ГОТОВО ДО ПРОШИВКИ" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#444" />
                            <TextBlock x:Name="ResultDetail" Text="Натисніть кнопку нижче, щоб прошити плату" FontSize="20" HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="#444" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" x:Name="AuthHintBanner" Visibility="Collapsed"
                            Background="#FFF3CD" BorderBrush="#FFEAA7" BorderThickness="1"
                            CornerRadius="6" Margin="20,0,20,10" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="AuthHintText" VerticalAlignment="Center"
                                       FontSize="14" Foreground="#6B5A0E" TextWrapping="Wrap"
                                       Text="Цей продукт потребує авторизації GitHub для завантаження прошивки." />
                            <Button    Grid.Column="1" x:Name="AuthHintLoginButton" Content="Увійти"
                                       Padding="14,6" Margin="12,0,0,0" Click="AuthHintLogin_Click" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="3" x:Name="FlashButton" Height="76"
                            Margin="20,0,20,12" Click="FlashButton_Click"
                            Background="#0078D7" Foreground="White" BorderThickness="0">
                        <Button.ToolTip>
                            <TextBlock x:Name="FlashButtonTooltipText"
                                       Text="Запустити прошивку поточної плати"
                                       FontSize="13" />
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="ПРОШИТИ ПЛАТУ" FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="FlashHotkeyHint" Text="(або натисніть Enter)"
                                       FontSize="12" Opacity="0.85"
                                       HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>

                    <Grid Grid.Row="4" Margin="20,0,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Деталі gdb:" FontSize="13" Foreground="#666" Margin="0,0,0,4" />
                        <TextBox Grid.Row="1" x:Name="GdbOutput"
                                 FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11"
                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                 Background="#1E1E1E" Foreground="#DCDCDC" Padding="6"
                                 TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================ HISTORY TAB ============================ -->
            <TabItem Header="Історія" FontSize="14">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="BatchSummary" FontSize="15" Text="Завантаження..." VerticalAlignment="Center" TextWrapping="Wrap" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Експорт CSV (партія)" Padding="12,6" Margin="0,0,6,0" Click="ExportCsvBatch_Click" />
                            <Button Content="Експорт CSV (все)"    Padding="12,6" Margin="0,0,6,0" Click="ExportCsvAll_Click" />
                            <Button x:Name="HistoryRefresh" Content="Оновити" Padding="14,6" Click="HistoryRefresh_Click" />
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#F4F4F4"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Час (UTC)"
                                                Binding="{Binding TsUtc, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                Width="160" />
                            <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="80" />
                            <DataGridTextColumn Header="Продукт" Binding="{Binding ProductId}" Width="120" />
                            <DataGridTextColumn Header="Версія" Binding="{Binding FirmwareVersion}" Width="100" />
                            <DataGridTextColumn Header="Партія" Binding="{Binding BatchId}" Width="120" />
                            <DataGridTextColumn Header="Оператор" Binding="{Binding Operator}" Width="120" />
                            <DataGridTextColumn Header="мс" Binding="{Binding DurationMs}" Width="60" />
                            <DataGridTextColumn Header="Помилка" Binding="{Binding ErrorCode}" Width="170" />
                            <DataGridTextColumn Header="Ціль (BMP)" Binding="{Binding TargetDetected}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ============================ CATALOG TAB ============================ -->
            <TabItem Header="Каталог" FontSize="14">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="CatalogHeader" VerticalAlignment="Center" FontSize="15" Text="Каталог не завантажено." />
                        <Button Grid.Column="1" Content="Перезавантажити" Padding="14,6" Click="CatalogReload_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CatalogProductsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="14" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{Binding ProductId}" FontWeight="Bold" FontSize="16" />
                                                <Run Text=" — " />
                                                <Run Text="{Binding DisplayName}" FontSize="14" />
                                            </TextBlock>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Ціль:" Foreground="#666" />
                                                <TextBlock Grid.Column="1">
                                                    <Run Text="{Binding Target.BmpMatch}" FontWeight="Bold" />
                                                    <Run Text=" (" />
                                                    <Run Text="{Binding Target.PartNumber}" />
                                                    <Run Text=", " />
                                                    <Run Text="{Binding Target.FlashKb}" />
                                                    <Run Text=" KB)" />
                                                </TextBlock>
                                            </Grid>

                                            <TextBlock Margin="0,10,0,4" Foreground="#666">
                                                <Run Text="Релізи (за замовчуванням: " />
                                                <Run Text="{Binding DefaultRelease}" FontWeight="Bold" />
                                                <Run Text="):" />
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding Releases}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F6F6F6" Padding="10" Margin="0,2,0,2" CornerRadius="4">
                                                            <StackPanel>
                                                                <TextBlock>
                                                                    <Run Text="v" />
                                                                    <Run Text="{Binding Version}" FontWeight="Bold" />
                                                                </TextBlock>
                                                                <TextBlock FontSize="12" Foreground="#444">
                                                                    <Run Text="Тип: " />
                                                                    <Run Text="{Binding FirmwareKind}" FontWeight="Bold" />
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding ElfFilename}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Foreground="#444" />
                                                                <TextBlock FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="#666">
                                                                    <Run Text="SHA-256: " />
                                                                    <Run Text="{Binding ElfSha256}" />
                                                                </TextBlock>
                                                                <TextBlock FontSize="11" Foreground="#888">
                                                                    <Run Text="Дата: " />
                                                                    <Run Text="{Binding ReleasedAt, StringFormat=yyyy-MM-dd}" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ============================ SETTINGS TAB ============================ -->
            <TabItem Header="Налаштування" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" MaxWidth="780" HorizontalAlignment="Left">

                        <!-- Catalog -->
                        <TextBlock Text="Каталог прошивок" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="catalog.json / sideload:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsCatalogPath" Margin="0,4,8,4" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickCatalogPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Обовʼязковий підпис:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="SettingsRequireSigned" Margin="0,8,0,4"
                                       Content="Відмовляти у роботі, якщо catalog.json не підписано Ed25519 (вимикати лише в лабораторії)" />
                        </Grid>

                        <!-- Auto-update catalog from iskra-catalog repo (Sprint 3.5) -->
                        <TextBlock Text="Каталог GitHub (авто-оновлення)" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Авто-оновлення:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <CheckBox  Grid.Row="0" Grid.Column="1" x:Name="SettingsCatalogAutoUpdate" Margin="0,8,0,4"
                                       Content="Завантажувати свіжий каталог з iskra-catalog при запуску" />

                            <!-- Sprint 6: catalog source is hard-locked to CatalogTrust.OfficialCatalogSource.
                                 Settings.json values that disagree are clamped back on load. The official source
                                 is displayed read-only here so the operator can see what the station trusts. -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Джерело (заблоковано):" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SettingsCatalogSourceLocked"
                                       VerticalAlignment="Center" Margin="0,4,8,4" FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#444" Text="…"
                                       ToolTip="Джерело каталогу зашите у застосунок (CatalogTrust.AllowedCatalogSources). Змінюється лише новою збіркою." />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Поточна версія:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CatalogCacheStatus"
                                       VerticalAlignment="Center" Margin="0,4,8,4" Text="…" TextWrapping="Wrap" />
                            <Button    Grid.Row="2" Grid.Column="2" x:Name="CatalogUpdateButton"
                                       Content="Перевірити оновлення" Padding="14,4" Margin="0,4,0,4"
                                       Click="CatalogUpdate_Click" />
                        </Grid>

                        <!-- App update check -->
                        <TextBlock Text="Оновлення застосунку Iskra" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Поточна версія:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AppUpdateCurrentVersion"
                                       VerticalAlignment="Center" Margin="0,4,8,4" FontFamily="Cascadia Mono, Consolas"
                                       Text="…" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Релізи:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AppUpdateSourceLocked"
                                       VerticalAlignment="Center" Margin="0,4,8,4" FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#444" Text="…" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Стан:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AppUpdateStatusLabel"
                                       VerticalAlignment="Center" Margin="0,4,8,4" Text="…" TextWrapping="Wrap" />
                            <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="0,4,0,4">
                                <Button x:Name="AppUpdateCheckButton"
                                        Content="Перевірити" Padding="14,4" Margin="0,0,8,0"
                                        Click="AppUpdateCheck_Click" />
                                <Button x:Name="AppUpdateOpenButton"
                                        Content="Відкрити реліз" Padding="14,4"
                                        Click="AppUpdateOpen_Click" />
                            </StackPanel>
                        </Grid>

                        <!-- GitHub auth -->
                        <TextBlock Text="Авторизація GitHub" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Стан:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AuthStatusLabel"
                                       VerticalAlignment="Center" Margin="0,4,8,4" Text="…" TextWrapping="Wrap" />
                            <Button    Grid.Row="0" Grid.Column="2" x:Name="AuthRefreshButton"
                                       Content="Оновити" Padding="10,4" Margin="0,4,0,4"
                                       Click="AuthRefresh_Click" />

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,4">
                                <Button x:Name="AuthLoginButton"  Content="Увійти" Padding="14,6" Margin="0,0,8,0" Click="AuthLogin_Click" />
                                <Button x:Name="AuthLogoutButton" Content="Вийти"  Padding="14,6" Click="AuthLogout_Click" />
                            </StackPanel>
                        </Grid>

                        <!-- Debugger / BMP -->
                        <TextBlock Text="Відлагоджувач (Black Magic Probe)" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Шлях до arm-none-eabi-gdb:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsGdbPath" Margin="0,4,8,4"
                                       ToolTip="Залиште порожнім для авто-визначення" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickGdbPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Частота SWD, Hz:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SettingsBmpFreq" Margin="0,4,8,4" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Живлення:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,4">
                                <RadioButton x:Name="SettingsPowerExternal" Content="Зовнішнє" GroupName="Power" Margin="0,0,16,0" />
                                <RadioButton x:Name="SettingsPowerProbe"    Content="Від BMP (tpwr)" GroupName="Power" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Connect-under-reset:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="SettingsConnectReset" Margin="0,8,0,4"
                                       Content="Утримувати NRST при підключенні (для чипів зі сплячим SWD)" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Тайм-аут, сек:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="SettingsTimeout" Margin="0,4,8,4" />
                        </Grid>

                        <!-- Logging / Station -->
                        <TextBlock Text="Журнал і станція" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Файл журналу (.db):" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsDbPath" Margin="0,4,8,4"
                                       ToolTip="Залиште порожнім для %LOCALAPPDATA%\Iskra\flash_log.db" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickDbPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ID станції:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SettingsStationId" Margin="0,4,8,4" />
                        </Grid>

                        <!-- Operator-configurable flash hotkey -->
                        <TextBlock Text="Інтерфейс оператора" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Гаряча клавіша прошивки:"
                                       VerticalAlignment="Center" Margin="0,4,8,4" />
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SettingsFlashHotkey"
                                      Margin="0,4,8,4" Padding="6,3"
                                      ToolTip="Клавіша, що натискає кнопку «Прошити плату». Enter зручно поєднується зі сканером штрих-кодів.">
                                <ComboBoxItem Content="(вимкнено)" Tag="None" />
                                <ComboBoxItem Content="Enter"      Tag="Enter" />
                                <ComboBoxItem Content="Пробіл"     Tag="Space" />
                                <ComboBoxItem Content="F2"         Tag="F2" />
                                <ComboBoxItem Content="F5"         Tag="F5" />
                            </ComboBox>
                        </Grid>

                        <!-- Sprint 5: cloud log mirror -->
                        <TextBlock Text="Хмарний журнал (iskra-logs)" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox  Grid.Row="0" Grid.Column="1" x:Name="SettingsLogShippingEnabled" Margin="0,4,0,4"
                                       Content="Авто-вивантажувати журнал у GitHub" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Інтервал (хв):" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SettingsLogShipInterval" Margin="0,4,8,4"
                                       ToolTip="Як часто фонова черга підштовхує несинхронізовані рядки" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Приватний ключ (.pem):" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="SettingsLogShipperKey" Margin="0,4,8,4"
                                       ToolTip="Файл приватного ключа GitHub App (за замовчанням %PROGRAMDATA%\Iskra\station-app.pem)" />
                            <Button    Grid.Row="2" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickLogKeyPath_Click" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Репозиторій:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SettingsLogsSourceLocked"
                                       FontStyle="Italic" Foreground="#555" Margin="0,4,8,4" VerticalAlignment="Center" />

                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="LogShipNowButton" Content="Вивантажити зараз"
                                        Padding="14,6" Margin="0,0,8,0" Click="LogShipNow_Click" />
                                <TextBlock x:Name="LogShipStatus" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Зберегти"      Padding="20,8" Margin="0,0,8,0" FontWeight="Bold" Background="#0078D7" Foreground="White" BorderThickness="0" Click="SettingsSave_Click" />
                            <Button Content="Скинути до замовчень" Padding="14,8" Margin="0,0,8,0" Click="SettingsReset_Click" />
                            <TextBlock x:Name="SettingsStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#1B8A1B" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
